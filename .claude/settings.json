{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npx *)",
      "Read",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(cat .env*)",
      "Bash(cat secrets/*)",
      "Read(.env*)",
      "Read(secrets/*)",
      "Edit(.env*)",
      "Edit(secrets/*)",
      "Write(.env*)",
      "Write(secrets/*)"
    ]
  }
}
